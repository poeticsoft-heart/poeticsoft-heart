{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "poeticsoft-heart/blockbase",
    "version": "1.0.1",
    "title": "Block Base",
    "category": "poeticsoft-heart-base",
    "icon": "smiley",
    "description": "Base block scaffolding with common attributes and controls.",
    "attributes": {
        "message": {
            "type": "string",
            "default": "Hello from Block Base!"
        },
        "showIcon": {
            "type": "boolean",
            "default": true
        }
    },
    "supports": {
        "html": false,
        "align": ["wide", "full"],
        "color": {
            "text": true,
            "background": true,
            "link": true
        }
    },
    "textdomain": "poeticsoft-heart",
    "editorScript": "file:./build/edit.js",
    "editorStyle": "file:./build/edit.css",
    "viewScript": "file:./build/view.js",
    "style": "file:./build/view.css",
    "render": "file:./render.php"
}
